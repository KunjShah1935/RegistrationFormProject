@model IEnumerable<RegistrationFormProject.Models.UserDocument>
@{
    ViewData["Title"] = "KYC Status";
    bool isProfileVerified = ViewBag.IsProfileVerified ?? false;
}

<div class="container py-5">
    <div class="card shadow border-0 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-radius: 24px;">
        <div class="text-center mb-5">
            <div class="login-icon mb-4">
                @(isProfileVerified ? "✅" : "⏳")
            </div>
            <h1 class="fw-bold mb-2 text-dark">KYC Verification Status</h1>
            <p class="text-muted">
                @if (isProfileVerified)
                {
                    <span class="text-success fw-bold fs-5">
                        <i class="bi bi-patch-check-fill me-2"></i>Your profile is fully verified! You now have unrestricted access.
                    </span>
                }
                else
                {
                    <span>Your documents are currently undergoing review. Please check their status below.</span>
                }
            </p>
        </div>

        @if (!isProfileVerified)
        {
            <div class="alert alert-warning mb-4 border-0 shadow-sm d-flex align-items-center gap-3 p-3" style="background: rgba(255, 193, 7, 0.15); border-radius: 16px;">
                <i class="bi bi-info-circle-fill text-warning fs-3"></i>
                <div>
                    <h6 class="alert-heading fw-bold mb-1 text-warning-emphasis">Profile Verification Pending</h6>
                    <p class="mb-0 text-muted small">You will gain access to the application routes once the Administrator approves your Aadhaar and PAN documents.</p>
                </div>
            </div>
        }

        <div class="table-responsive rounded-4 border overflow-hidden">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary fw-semibold">Document Type</th>
                        <th class="py-3 text-secondary fw-semibold">Uploaded File</th>
                        <th class="py-3 text-secondary fw-semibold">Upload Date</th>
                        <th class="py-3 text-secondary fw-semibold">Status</th>
                        <th class="px-4 py-3 text-end text-secondary fw-semibold">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model)
                    {
                        <tr>
                            <td class="px-4 fw-semibold text-dark">
                                @doc.DocumentType
                            </td>
                            <td class="text-muted text-truncate" style="max-width: 200px;">
                                @doc.FileName
                            </td>
                            <td class="text-muted">
                                @doc.UploadedDate.ToString("dd MMM yyyy, hh:mm tt")
                            </td>
                            <td>
                                @if (doc.IsVerified)
                                {
                                    <span class="badge bg-success text-white px-3 py-2 rounded-pill">
                                        <i class="bi bi-check-circle-fill me-1"></i> Verified
                                    </span>
                                }
                                else if (doc.NeedsReupload)
                                {
                                    <span class="badge bg-danger text-white px-3 py-2 rounded-pill" data-bs-toggle="tooltip" title="@doc.ReuploadReason">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> Re-upload Required
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                        <i class="bi bi-clock-fill me-1"></i> Pending Review
                                    </span>
                                }
                            </td>
                            <td class="px-4 text-end">
                                @if (doc.NeedsReupload)
                                {
                                    <button class="btn btn-sm btn-danger px-3 rounded-pill" type="button" data-bs-toggle="collapse" data-bs-target="#reupload-@doc.DocumentId" aria-expanded="false" aria-controls="reupload-@doc.DocumentId">
                                        <i class="bi bi-arrow-repeat me-1"></i> Fix Re-upload
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">No Action Required</span>
                                }
                            </td>
                        </tr>
                        @if (doc.NeedsReupload)
                        {
                            <tr class="collapse" id="reupload-@doc.DocumentId">
                                <td colspan="5" class="px-4 py-3" style="background: rgba(220, 53, 69, 0.03);">
                                    <div class="p-3 border border-danger-subtle rounded-3 bg-white shadow-sm">
                                        <div class="text-danger fw-semibold mb-3">
                                            <i class="bi bi-x-circle-fill me-1"></i> Rejection Reason: <span class="text-dark fw-normal">@(string.IsNullOrEmpty(doc.ReuploadReason) ? "No reason specified" : doc.ReuploadReason)</span>
                                        </div>
                                        <form asp-controller="Verification" asp-action="Reupload" method="post" enctype="multipart/form-data">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                            <div class="row align-items-center">
                                                <div class="col-md-8 mb-2 mb-md-0">
                                                    <input type="file" name="file" class="form-control" accept="application/pdf" required />
                                                    <div class="form-text text-muted small mt-1">Accepts only PDFs under 2MB.</div>
                                                </div>
                                                <div class="col-md-4 text-md-end">
                                                    <button type="submit" class="btn btn-primary h-auto w-100 py-2 btn-login text-white d-flex align-items-center justify-content-center gap-2">
                                                        <i class="bi bi-cloud-arrow-up-fill"></i> Upload PDF
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
