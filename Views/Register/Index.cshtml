@model RegistrationFormProject.Models.UserMaster

<div class="mouse-glow"></div>

<div class="container py-4">

    <div class="card registration-card mx-auto">

        <div class="text-center mb-4">

            <h1 class="fw-bold">
                Create Account
            </h1>

            <p class="text-muted mb-0">
                Fill in your details to get started
            </p>

        </div>

        <div asp-validation-summary="All"></div>

        <form method="post" enctype="multipart/form-data">

            <div class="row g-2">

                <div class="col-md-6">

                    <label class="form-label">
                        Full Name
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            👤
                        </span>

                        <input asp-for="FullName"
                               class="form-control" />

                    </div>

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        User Name
                    </label><span id="userError"
                                  class="text-danger"></span>

                    <div class="input-group">

                        <span class="input-group-text">
                             
                        </span>

                        <input asp-for="UserName"
                               class="form-control" />

                    </div>

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Password
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            🔒
                        </span>

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               id="Password" />

                    </div>
                    
                    <div class="password-strength-container mt-2">
                        <div class="progress" style="height: 6px; background-color: rgba(255,255,255,0.15);">
                            <div id="strengthBar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-1">
                            <small id="strengthText" class="text-muted fw-semibold">Strength: Not Set</small>
                        </div>
                        <ul class="list-unstyled mt-2 pl-0" style="margin-left: 0; padding-left: 0;">
                            <li id="req-length" class="text-danger small mb-1"><i class="bi bi-x-circle-fill me-1"></i> Minimum 8 characters</li>
                            <li id="req-upper" class="text-danger small mb-1"><i class="bi bi-x-circle-fill me-1"></i> At least 1 uppercase letter</li>
                            <li id="req-lower" class="text-danger small mb-1"><i class="bi bi-x-circle-fill me-1"></i> At least 1 lowercase letter</li>
                            <li id="req-number" class="text-danger small mb-1"><i class="bi bi-x-circle-fill me-1"></i> At least 1 number</li>
                            <li id="req-special" class="text-danger small mb-1"><i class="bi bi-x-circle-fill me-1"></i> At least 1 special character</li>
                        </ul>
                    </div>

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Confirm Password
                    </label>

                    <div class="input-group">

                        <span class="input-group-text">
                            🔒
                        </span>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control" />

                    </div>

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Email
                    </label><span id="emailError"
                                  class="text-danger"></span>

                    <input asp-for="EmailID"
                           class="form-control" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Mobile Number
                    </label><span id="mobileError"
                                  class="text-danger"></span>

                    <input asp-for="MobileNo"
                           class="form-control" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Date Of Birth
                    </label>

                    <input asp-for="DOB"
                           type="date"
                           class="form-control" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">
                        Role
                    </label>

                    <select asp-for="RoleId"
                            class="form-select">

                        <option value="">
                            Select Role
                        </option>

                        <option value="1">
                            Admin
                        </option>

                        <option value="2">
                            User
                        </option>

                    </select>

                </div>

                <div class="col-12">

                    <label class="form-label">
                        Gender
                    </label>

                    <div class="d-flex gap-3">

                        <label class="gender-pill">
                            <input type="radio"
                                   asp-for="Gender"
                                   value="Male" />
                            Male
                        </label>

                        <label class="gender-pill">
                            <input type="radio"
                                   asp-for="Gender"
                                   value="Female" />
                            Female
                        </label>

                        <label class="gender-pill">
                            <input type="radio"
                                   asp-for="Gender"
                                   value="Other" />
                            Other
                        </label>

                    </div>

                </div>

                <!-- Mandatory Documents Upload -->
                <div class="col-12 mt-4 border-top pt-4">
                    <h5 class="mb-3 text-primary fw-bold">KYC Verification Documents (Mandatory)</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Aadhaar Card (PDF only, max 2MB) <span class="text-danger">*</span></label>
                            <input type="file" name="AadhaarFile" class="form-control" accept="application/pdf" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">PAN Card (PDF only, max 2MB) <span class="text-danger">*</span></label>
                            <input type="file" name="PanFile" class="form-control" accept="application/pdf" required />
                        </div>
                    </div>
                </div>

                <!-- Optional Documents Upload -->
                <div class="col-12 mt-4 border-top pt-4 mb-3">
                    <h5 class="mb-3 text-muted fw-bold">Optional KYC Documents (PDF only, max 2MB)</h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Passport (PDF)</label>
                            <input type="file" name="PassportFile" class="form-control" accept="application/pdf" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Driving License (PDF)</label>
                            <input type="file" name="DrivingLicenseFile" class="form-control" accept="application/pdf" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Voter ID (PDF)</label>
                            <input type="file" name="VoterIdFile" class="form-control" accept="application/pdf" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ration Card (PDF)</label>
                            <input type="file" name="RationCardFile" class="form-control" accept="application/pdf" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Others (PDF)</label>
                            <input type="file" name="OthersFile" class="form-control" accept="application/pdf" />
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-3">

                    <label class="form-label fw-semibold text-muted mb-2">
                        Security Verification
                    </label>

                    <div class="captcha-container mb-3">

                        <div class="captcha-image-wrapper">

                            <img id="captchaImage"
                                 src="/Captcha/GenerateCaptcha"
                                 alt="CAPTCHA Image" />

                        </div>

                        <button type="button"
                                class="btn btn-refresh-captcha"
                                onclick="refreshCaptcha()">

                            <i class="bi bi-arrow-clockwise"></i>

                        </button>

                    </div>

                    <div class="input-group">

                        <span class="input-group-text">
                            🛡️
                        </span>

                        <input type="text"
                               name="captchaInput"
                               class="form-control"
                               placeholder="Enter Security Code"
                               required
                               autocomplete="off" />

                    </div>

                </div>

                <div class="col-12 mt-2">

                    <button type="submit"
                            class="btn btn-register w-100">

                        Create Account

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<script>

document.addEventListener('mousemove', function(e){

    const glow = document.querySelector('.mouse-glow');

    glow.style.left = e.clientX + 'px';
    glow.style.top = e.clientY + 'px';

});

function refreshCaptcha() {
    const img = document.getElementById("captchaImage");
    if (img) {
        img.classList.add("loading");
        img.src = "/Captcha/GenerateCaptcha?" + new Date().getTime();
        img.onload = function() {
            img.classList.remove("loading");
        };
    }
    
}

</script>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#UserName").keyup(function () {
                $.get("/Register/CheckUsername", { username: $(this).val() }, function (data) {
                    $("#userError").text(data ? "" : "Username already exists");
                });
            });

            $("#EmailID").keyup(function () {
                $.get("/Register/CheckEmail", { email: $(this).val() }, function (data) {
                    $("#emailError").text(data ? "" : "Email already exists");
                });
            });

            $("#MobileNo").keyup(function () {
                $.get("/Register/CheckMobile", { mobile: $(this).val() }, function (data) {
                    $("#mobileError").text(data ? "" : "Mobile already exists");
                });
            });

            // Password strength meter logic
            const passwordInput = document.getElementById('Password');
            const strengthBar = document.getElementById('strengthBar');
            const strengthText = document.getElementById('strengthText');

            const reqLength = document.getElementById('req-length');
            const reqUpper = document.getElementById('req-upper');
            const reqLower = document.getElementById('req-lower');
            const reqNumber = document.getElementById('req-number');
            const reqSpecial = document.getElementById('req-special');

            function updateReq(element, isValid) {
                if (element) {
                    const icon = element.querySelector('i');
                    if (isValid) {
                        if (icon) icon.className = "bi bi-check-circle-fill text-success me-1";
                        element.className = "text-success small mb-1";
                    } else {
                        if (icon) icon.className = "bi bi-x-circle-fill text-danger me-1";
                        element.className = "text-danger small mb-1";
                    }
                }
            }

            let isPasswordStrong = false;

            if (passwordInput) {
                passwordInput.addEventListener('input', function() {
                    const val = passwordInput.value;
                    
                    const checks = {
                        length: val.length >= 8,
                        upper: /[A-Z]/.test(val),
                        lower: /[a-z]/.test(val),
                        number: /[0-9]/.test(val),
                        special: /[^A-Za-z0-9]/.test(val)
                    };
                    
                    updateReq(reqLength, checks.length);
                    updateReq(reqUpper, checks.upper);
                    updateReq(reqLower, checks.lower);
                    updateReq(reqNumber, checks.number);
                    updateReq(reqSpecial, checks.special);
                    
                    let score = 0;
                    if (checks.length) score++;
                    if (checks.upper) score++;
                    if (checks.lower) score++;
                    if (checks.number) score++;
                    if (checks.special) score++;
                    
                    let strength = "Not Set";
                    let barClass = "bg-secondary";
                    let barWidth = "0%";
                    isPasswordStrong = false;
                    
                    if (val.length > 0) {
                        if (score <= 1) {
                            strength = "Weak";
                            barClass = "bg-danger";
                            barWidth = "25%";
                        } else if (score <= 3) {
                            strength = "Ok";
                            barClass = "bg-warning";
                            barWidth = "50%";
                        } else if (score === 4) {
                            strength = "Good";
                            barClass = "bg-info";
                            barWidth = "75%";
                        } else if (score === 5) {
                            strength = "Strong";
                            barClass = "bg-success";
                            barWidth = "100%";
                            isPasswordStrong = true;
                        }
                    }
                    
                    if (strengthText) strengthText.textContent = "Strength: " + strength;
                    if (strengthBar) {
                        strengthBar.className = "progress-bar " + barClass;
                        strengthBar.style.width = barWidth;
                    }
                });
            }

            // Client-side XSS and password validation checks on form submission
            $('form').on('submit', function (e) {
                // 1. Password Strength enforcement
                if (passwordInput && passwordInput.value.length > 0 && !isPasswordStrong) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'Weak Password',
                        text: 'Please make sure your password satisfies all security requirements (Strong status) before submitting.',
                        confirmButtonColor: '#2563eb'
                    });
                    return false;
                }

                // 2. Client-side XSS prevention
                let hasXss = false;
                // Exclude password and file uploads from generic character filtering
                const inputs = $(this).find('input[type="text"], input[type="email"], select, textarea');
                
                inputs.each(function () {
                    const value = $(this).val();
                    if (value && /[<>]/.test(value)) {
                        hasXss = true;
                        const fieldLabel = $(this).closest('.col-md-6, .col-12').find('label').text().trim() || $(this).attr('name');
                        Swal.fire({
                            icon: 'error',
                            title: 'Potential Security Threat',
                            text: `HTML/Script characters (< or >) are not allowed in the "${fieldLabel}" field.`,
                            confirmButtonColor: '#dc3545'
                        });
                        return false; // Break jquery loop
                    }
                });

                if (hasXss) {
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}