@{
    ViewData["Title"] = "Document Preview";
}

<div class="card shadow">

    <div class="card-header bg-dark text-white">

        <h3>
            @ViewBag.FileName
        </h3>

    </div>

    <div class="card-body">

        <iframe src="@ViewBag.FilePath"
                width="100%"
                height="800px"
                style="border:none;">
        </iframe>

    </div>

</div>