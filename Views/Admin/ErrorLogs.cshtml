@model List<RegistrationFormProject.Models.ErrorLog>
@{
    ViewData["Title"] = "System Error Logs";
}

<div class="card shadow border-0 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-radius: 24px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">System Error Logs</h2>
            <p class="text-muted mb-0">Track and debug unhandled system exceptions and user errors.</p>
        </div>
        @if (Model.Any())
        {
            <form asp-action="ClearErrorLogs" method="post" id="clearErrorForm">
                @Html.AntiForgeryToken()
                <button type="button" onclick="confirmClearErrorLogs()" class="btn btn-outline-danger px-4 rounded-pill">
                    <i class="bi bi-trash3-fill me-1"></i> Clear All Logs
                </button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="fs-1 text-success mb-3">🛡️</div>
            <h4 class="fw-bold text-success">All Clear!</h4>
            <p class="text-muted mb-0">No unhandled exceptions have been recorded in the system.</p>
        </div>
    }
    else
    {
        <div class="table-responsive rounded-4 border overflow-hidden shadow-sm bg-white">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary fw-semibold">ID</th>
                        <th class="py-3 text-secondary fw-semibold">User context</th>
                        <th class="py-3 text-secondary fw-semibold">Route</th>
                        <th class="py-3 text-secondary fw-semibold">Message</th>
                        <th class="py-3 text-secondary fw-semibold">Timestamp</th>
                        <th class="px-4 py-3 text-end text-secondary fw-semibold">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="px-4 fw-semibold text-muted">#@log.ErrorLogId</td>
                            <td class="fw-semibold text-dark">
                                @if (log.UserId != null)
                                {
                                    <span>@log.UserName <small class="text-muted font-monospace">(ID: @log.UserId)</small></span>
                                }
                                else
                                {
                                    <span class="text-muted font-monospace">Anonymous</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1 rounded">
                                    @log.ControllerName / @log.ActionName
                                </span>
                            </td>
                            <td class="text-danger text-truncate" style="max-width: 300px;" data-bs-toggle="tooltip" title="@log.ErrorMessage">
                                @log.ErrorMessage
                            </td>
                            <td class="text-muted small">
                                @log.LoggedDate.ToString("dd MMM yyyy, hh:mm tt")
                            </td>
                            <td class="px-4 text-end">
                                <button class="btn btn-sm btn-outline-primary px-3 rounded-pill" type="button" data-bs-toggle="collapse" data-bs-target="#stacktrace-@log.ErrorLogId" aria-expanded="false" aria-controls="stacktrace-@log.ErrorLogId">
                                    <i class="bi bi-code-slash me-1"></i> Stack Trace
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="stacktrace-@log.ErrorLogId">
                            <td colspan="6" class="px-4 py-3 bg-light border-top-0">
                                <div class="p-3 border rounded-3 bg-dark text-white font-monospace small overflow-auto shadow-inner" style="max-height: 250px;">
                                    <div class="text-warning fw-bold mb-2">Exception: @log.ErrorMessage</div>
                                    <pre class="mb-0 text-light" style="white-space: pre-wrap;">@log.StackTrace</pre>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmClearErrorLogs() {
            Swal.fire({
                title: 'Clear Error Logs?',
                text: 'Are you sure you want to permanently delete all unhandled error records? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Clear All',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('clearErrorForm').submit();
                }
            });
        }
    </script>
}
