@model RegistrationFormProject.Models.RoleMaster

<div class="container py-5 d-flex justify-content-center">

    <div class="card shadow-lg p-5 w-100">

        <h2 class="text-center mb-4">
            Edit Role
        </h2>

        <form method="post">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        RoleId
                    </label>

                    <input asp-for="RoleId"
                           class="form-control" />

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Role Name
                    </label>

                    <input asp-for="RoleName"
                           class="form-control" />

                </div>

                 

                <div class="col-12 d-grid">

                    <button type="submit"
                            class="btn btn-primary">

                        Update Role

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>