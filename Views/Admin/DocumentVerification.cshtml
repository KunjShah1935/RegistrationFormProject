@model List<RegistrationFormProject.ViewModels.DocumentVerificationVM>

<div class="card shadow-lg border-0">

    <div class="card-header bg-dark text-white">

        <h3 class="mb-0">

            Document Verification

        </h3>

    </div>

    <div class="card-body">

        <table class="table table-hover align-middle">

            <thead>

                <tr>

                    <th>User Name</th>

                    <th>Document Type</th>

                    <th>File Name</th>

                    <th>Status</th>

                    <th>Action</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var doc in Model)
                {
                    <tr>

                        <td>@doc.FullName</td>

                        <td>@doc.DocumentType</td>

                        <td>@doc.FileName</td>

                        <td>

                            @if (doc.IsVerified)
                            {
                                <span class="badge bg-success">

                                    Verified

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">

                                    Pending

                                </span>
                            }

                        </td>

                        <td>

                            <a asp-controller="Document"
                               asp-action="ViewDocument"
                               asp-route-id="@doc.DocumentId"
                               class="btn btn-outline-primary btn-sm">

                                View

                            </a>

                            @if (!doc.IsVerified)
                            {
                                <a asp-action="VerifyDocument"
                                   asp-route-id="@doc.DocumentId"
                                   class="btn btn-success btn-sm">

                                    Verify

                                </a>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>