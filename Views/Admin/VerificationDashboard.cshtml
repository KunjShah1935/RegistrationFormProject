@model List<RegistrationFormProject.Models.UserVerificationVM>
@{
    ViewData["Title"] = "KYC Verification Dashboard";
}

<div class="card shadow border-0 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-radius: 24px;">
    <div class="mb-4">
        <h2 class="fw-bold mb-1 text-dark">KYC Verification Dashboard</h2>
        <p class="text-muted mb-0">Monitor and verify user identity documents for compliance.</p>
    </div>

    <div class="table-responsive rounded-4 border overflow-hidden">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="px-4 py-3 text-secondary fw-semibold">User ID</th>
                    <th class="py-3 text-secondary fw-semibold">Full Name</th>
                    <th class="py-3 text-secondary fw-semibold text-center">Total Docs</th>
                    <th class="py-3 text-secondary fw-semibold text-center">Verified</th>
                    <th class="py-3 text-secondary fw-semibold text-center">Re-upload Requests</th>
                    <th class="py-3 text-secondary fw-semibold">Status</th>
                    <th class="px-4 py-3 text-end text-secondary fw-semibold">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="px-4 fw-semibold text-muted">#@user.UserId</td>
                        <td class="fw-semibold text-dark">@user.FullName</td>
                        <td class="text-center text-secondary fw-bold">@user.TotalDocuments</td>
                        <td class="text-center text-success fw-bold">@user.VerifiedDocuments</td>
                        <td class="text-center text-danger fw-bold">@user.ReuploadDocuments</td>
                        <td>
                            @if (user.VerificationStatus == "Verified")
                            {
                                <span class="badge bg-success text-white px-3 py-2 rounded-pill">
                                    <i class="bi bi-patch-check-fill me-1"></i> Verified
                                </span>
                            }
                            else if (user.VerificationStatus == "Re-upload Required")
                            {
                                <span class="badge bg-danger text-white px-3 py-2 rounded-pill">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Re-upload Required
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                    <i class="bi bi-clock-fill me-1"></i> Pending Review
                                </span>
                            }
                        </td>
                        <td class="px-4 text-end">
                            <a asp-action="ReviewUserDocuments"
                               asp-route-id="@user.UserId"
                               class="btn btn-primary btn-sm px-4 rounded-pill text-white d-inline-flex align-items-center gap-1">
                                <i class="bi bi-pencil-square"></i> Review
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>