@model List<RegistrationFormProject.Models.ActivityLog>
@{
    ViewData["Title"] = "User Activity Audit Logs";
}

<div class="card shadow border-0 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-radius: 24px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">User Activity Audit Logs</h2>
            <p class="text-muted mb-0">Monitor and audit actions performed by users and administrators.</p>
        </div>
        @if (Model.Any())
        {
            <form asp-action="ClearActivityLogs" method="post" id="clearActivityForm">
                @Html.AntiForgeryToken()
                <button type="button" onclick="confirmClearActivityLogs()" class="btn btn-outline-danger px-4 rounded-pill">
                    <i class="bi bi-trash3-fill me-1"></i> Clear All Logs
                </button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="fs-1 text-secondary mb-3">📭</div>
            <h4 class="fw-bold text-secondary">No Activity Logged</h4>
            <p class="text-muted mb-0">No actions have been performed on the portal yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive rounded-4 border overflow-hidden shadow-sm bg-white">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary fw-semibold">ID</th>
                        <th class="py-3 text-secondary fw-semibold">User Context</th>
                        <th class="py-3 text-secondary fw-semibold">Activity / Event</th>
                        <th class="py-3 text-secondary fw-semibold">IP Address</th>
                        <th class="px-4 py-3 text-secondary fw-semibold">Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="px-4 fw-semibold text-muted">#@log.ActivityLogId</td>
                            <td class="fw-semibold text-dark">
                                @if (log.UserId != null)
                                {
                                    <span>@log.UserName <small class="text-muted font-monospace">(ID: @log.UserId)</small></span>
                                }
                                else
                                {
                                    <span class="text-muted font-monospace">Anonymous</span>
                                }
                            </td>
                            <td>
                                @if (log.Activity.Contains("successfully") || log.Activity.Contains("approved") || log.Activity.Contains("activated"))
                                {
                                    <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> @log.Activity</span>
                                }
                                else if (log.Activity.Contains("Failed") || log.Activity.Contains("wrong") || log.Activity.Contains("suspended") || log.Activity.Contains("deactivated"))
                                {
                                    <span class="text-danger"><i class="bi bi-exclamation-octagon-fill me-1"></i> @log.Activity</span>
                                }
                                else
                                {
                                    <span class="text-dark">@log.Activity</span>
                                }
                            </td>
                            <td class="font-monospace text-muted small">
                                @(string.IsNullOrEmpty(log.IpAddress) ? "::1" : log.IpAddress)
                            </td>
                            <td class="px-4 text-muted small">
                                @log.LoggedDate.ToString("dd MMM yyyy, hh:mm tt")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmClearActivityLogs() {
            Swal.fire({
                title: 'Clear Activity Logs?',
                text: 'Are you sure you want to permanently delete all user audit trail records? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Clear All',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('clearActivityForm').submit();
                }
            });
        }
    </script>
}
