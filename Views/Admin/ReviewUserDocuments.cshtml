@model List<RegistrationFormProject.ViewModels.DocumentVerificationVM>
@{
    ViewData["Title"] = "Review User Documents";
}

<div class="card shadow border-0 p-4 p-md-5" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-radius: 24px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">KYC Documents Review</h2>
            <p class="text-muted mb-0">Reviewing documents for <span class="fw-semibold text-primary">@ViewBag.FullName</span></p>
        </div>
        <a asp-action="VerificationDashboard" class="btn btn-outline-secondary px-4 rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    @Html.AntiForgeryToken()

    <div class="table-responsive rounded-4 border overflow-hidden">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="px-4 py-3 text-secondary fw-semibold">Document Type</th>
                    <th class="py-3 text-secondary fw-semibold">File Name</th>
                    <th class="py-3 text-secondary fw-semibold">Upload Date</th>
                    <th class="py-3 text-secondary fw-semibold">Status</th>
                    <th class="px-4 py-3 text-end text-secondary fw-semibold">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td class="px-4 fw-semibold text-dark">
                            @doc.DocumentType
                        </td>
                        <td class="text-muted">
                            @doc.FileName
                        </td>
                        <td class="text-muted">
                            @doc.UploadedDate.ToString("dd MMM yyyy, hh:mm tt")
                        </td>
                        <td>
                            @if (doc.IsVerified)
                            {
                                <span class="badge bg-success text-white px-3 py-2 rounded-pill">
                                    <i class="bi bi-check-circle-fill me-1"></i> Verified
                                </span>
                            }
                            else if (doc.NeedsReupload)
                            {
                                <span class="badge bg-danger text-white px-3 py-2 rounded-pill" data-bs-toggle="tooltip" title="@doc.ReuploadReason">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Re-upload Requested
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                    <i class="bi bi-clock-fill me-1"></i> Pending Review
                                </span>
                            }
                        </td>
                        <td class="px-4 text-end">
                            <div class="btn-group gap-1">
                                <a asp-action="PreviewDocument"
                                   asp-route-id="@doc.DocumentId"
                                   class="btn btn-primary btn-sm px-3 rounded-pill d-inline-flex align-items-center gap-1 text-white">
                                    <i class="bi bi-eye-fill"></i> View
                                </a>

                                <a asp-action="DownloadDocument"
                                   asp-route-id="@doc.DocumentId"
                                   class="btn btn-info btn-sm px-3 rounded-pill d-inline-flex align-items-center gap-1 text-white">
                                    <i class="bi bi-download"></i> Download
                                </a>

                                @if (!doc.IsVerified && !doc.NeedsReupload)
                                {
                                    <a asp-action="VerifyDocument"
                                       asp-route-id="@doc.DocumentId"
                                       class="btn btn-success btn-sm px-3 rounded-pill d-inline-flex align-items-center gap-1 text-white">
                                        <i class="bi bi-patch-check-fill"></i> Approve
                                    </a>

                                    <button type="button"
                                            onclick="requestReupload(@doc.DocumentId)"
                                            class="btn btn-danger btn-sm px-3 rounded-pill d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-x-circle-fill"></i> Reject
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function requestReupload(documentId) {
            Swal.fire({
                title: 'Request Re-upload',
                text: 'Please enter the reason for rejecting this document:',
                input: 'textarea',
                inputPlaceholder: 'Reason for rejection (e.g., PDF text blurry, incorrect document type, expired document)...',
                showCancelButton: true,
                confirmButtonText: 'Request Re-upload',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                preConfirm: (reason) => {
                    if (!reason || reason.trim() === '') {
                        Swal.showValidationMessage('A rejection reason is required.');
                    }
                    return reason;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '@Url.Action("RequestReupload", "Admin")';

                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    form.appendChild(tokenInput);

                    const idInput = document.createElement('input');
                    idInput.type = 'hidden';
                    idInput.name = 'documentId';
                    idInput.value = documentId;
                    form.appendChild(idInput);

                    const reasonInput = document.createElement('input');
                    reasonInput.type = 'hidden';
                    reasonInput.name = 'reason';
                    reasonInput.value = result.value;
                    form.appendChild(reasonInput);

                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}