@model RegistrationFormProject.Models.ForgotPasswordVM

<div class="card shadow mx-auto mt-5"
     style="max-width:500px;">

    <div class="card-header bg-dark text-white">

        <h4>

            Forgot Password

        </h4>

    </div>

    <div class="card-body">

        <div class="mb-3">

            <label>

                Username

            </label>

            <input id="username"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>

                Recovery Method

            </label>

            <select id="method"
                    class="form-select">

                <option value="Email">

                    Email OTP

                </option>

                <option value="Mobile">

                    Mobile OTP

                </option>

            </select>

        </div>

        <button id="sendOtp"
                class="btn btn-primary">

            Send OTP

        </button>

        <hr />

        <div id="otpSection"
             style="display:none;">

            <div class="mb-3">

                <label>

                    Enter OTP

                </label>

                <input id="otp"
                       class="form-control" />

            </div>

            <button id="verifyOtp"
                    class="btn btn-success">

                Verify OTP

            </button>

        </div>

        <div id="passwordSection"
             style="display:none;">

            <div class="mb-3">

                <label>

                    New Password

                </label>

                <input id="newPassword"
                       type="password"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label>

                    Confirm Password

                </label>

                <input id="confirmPassword"
                       type="password"
                       class="form-control" />

            </div>

            <button id="resetPassword"
                    class="btn btn-dark">

                Reset Password

            </button>

        </div>

    </div>

</div>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
@section Scripts
{
    <script>

        $(document).ready(function () {

        $("#sendOtp").click(function (e) {

        e.preventDefault();

        $.ajax({
        url: "/Login/SendOtp",
        type: "POST",
        data: {
        username: $("#username").val(),
        method: $("#method").val()
        },
        success: function (response) {

        alert(response.message);

        console.log(response);

        if (response.success) {

        $("#otpSection").show();

        }

        },
        error: function (xhr, status, error) {

        alert("Send OTP Failed");

        console.log(xhr);
        console.log(status);
        console.log(error);

        }
        });

        });

        $("#verifyOtp").click(function (e) {

        e.preventDefault();

        $.ajax({
        url: "/Login/VerifyOtp",
        type: "POST",
        data: {
        otp: $("#otp").val()
        },
        success: function (response) {

        alert(response.message);

        console.log(response);

        if (response.success) {

        $("#passwordSection").show();

        }

        },
        error: function (xhr, status, error) {

        alert("Verify OTP Failed");

        console.log(xhr);
        console.log(status);
        console.log(error);

        }
        });

        });

        $("#resetPassword").click(function (e) {

        e.preventDefault();

        $.ajax({
        url: "/Login/ResetPassword",
        type: "POST",
        data: {
        newPassword: $("#newPassword").val(),
        confirmPassword: $("#confirmPassword").val()
        },
        success: function (response) {

        alert(response.message);

        console.log(response);

        if (response.success) {

        window.location.href = "/Login";

        }

        },
        error: function (xhr, status, error) {

        alert("Reset Password Failed");

        console.log(xhr);
        console.log(status);
        console.log(error);

        }
        });

        });

        });

    </script>
}