<div class="container d-flex justify-content-center align-items-center py-5">

    <div class="login-card">

        <div class="text-center mb-5">

            <div class="login-icon mb-4">
                🔐
            </div>

            <h1 class="fw-bold mb-2">
                Welcome Back
            </h1>

            <p class="text-muted">
                Sign in to continue to your account
            </p>

        </div>

        <form method="post">

            <div class="input-group modern-input mb-4">

                <span class="input-group-text">
                    👤
                </span>

                <input type="text"
                       name="username"
                       class="form-control"
                       placeholder="Enter Username"
                       required />

            </div>

            <div class="input-group modern-input mb-4">

                <span class="input-group-text">
                    🔒
                </span>

                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="Enter Password"
                       required />

            </div>

            <div class="mb-4 text-start">

                <label class="form-label fw-semibold text-muted mb-2">
                    Security Verification
                </label>

                <div class="captcha-container mb-3">

                    <div class="captcha-image-wrapper">

                        <img id="captchaImage"
                             src="/Captcha/GenerateCaptcha"
                             alt="CAPTCHA Image" />

                    </div>

                    <button type="button"
                            class="btn btn-refresh-captcha"
                            onclick="refreshCaptcha()">

                        <i class="bi bi-arrow-clockwise"></i>

                    </button>

                </div>

                <div class="input-group modern-input">

                    <span class="input-group-text">
                        🛡️
                    </span>

                    <input type="text"
                           name="captchaInput"
                           class="form-control"
                           placeholder="Enter Security Code"
                           required
                           autocomplete="off" />

                </div>

            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div class="form-check mb-3">

                    <input class="form-check-input"
                           type="checkbox"
                           id="rememberMe"
                           name="rememberMe" />

                    <label class="form-check-label"
                           for="rememberMe">

                        Remember Me

                    </label>

                </div>

                <div class="text-center mt-3">
                    <a asp-controller="Login"
                       asp-action="ForgotPassword">

                        Forgot Password?

                    </a>
                </div>

            </div>

            <button type="submit"
                    class="btn btn-login w-100">

                Sign In

            </button>

        </form>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-danger mt-3">

                @ViewBag.Message

            </div>
        }

        <div class="text-center mt-4">

            <span class="text-muted">
                Don't have an account?
            </span>

            <a asp-controller="Register"
               asp-action="Index"
               class="fw-semibold text-decoration-none">

                Create Account

            </a>

        </div>

    </div>

</div>

<script>

    function refreshCaptcha() {
        const img = document.getElementById("captchaImage");
        if (img) {
            img.classList.add("loading");
            img.src = "/Captcha/GenerateCaptcha?" + new Date().getTime();
            img.onload = function() {
                img.classList.remove("loading");
            };
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        const form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', function (e) {
                const inputs = form.querySelectorAll('input[type="text"]');
                let hasXss = false;
                inputs.forEach(function (input) {
                    const value = input.value;
                    if (value && /[<>]/.test(value)) {
                        hasXss = true;
                        const labelText = input.placeholder || input.name || "input";
                        Swal.fire({
                            icon: 'error',
                            title: 'Potential Security Threat',
                            text: `HTML/Script characters (< or >) are not allowed in the "${labelText}" field.`,
                            confirmButtonColor: '#dc3545'
                        });
                    }
                });
                if (hasXss) {
                    e.preventDefault();
                }
            });
        }
    });

</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@if (TempData["Error"] != null)
{
    <script>

        Swal.fire({
        icon: 'error',
        title: 'Access Denied',
        text: '@TempData["Error"]',
        confirmButtonColor: '#dc3545'
        });

    </script>
}