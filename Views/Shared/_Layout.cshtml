@inject RegistrationFormProject.Data.ApplicationDbContext DbContext
@using System.Security.Claims
@{
    bool isProfileVerified = false;
    bool isUserRole = User.IsInRole("User");
    if (isUserRole)
    {
        var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdClaim, out int userId))
        {
            var user = DbContext.UserMasters.Find(userId);
            isProfileVerified = user?.IsProfileVerified ?? false;
        }
    }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - RegistrationFormProject
    </title>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet"
          href="~/RegistrationFormProject.styles.css"
          asp-append-version="true" />
</head>

<body>
    <div class="bg-animation">
        <div class="orb orb1"></div>
        <div class="orb orb2"></div>
        <div class="orb orb3"></div>
    </div>

    <header>

        <nav class="navbar navbar-expand-sm navbar-light border-bottom shadow-sm">

            <div class="container-fluid px-4 px-md-5">

                <a class="navbar-brand fw-bold text-primary"
                   asp-controller="Landing"
                   asp-action="Index">

                    RegistrationFormProject

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarNav">

                    <ul class="navbar-nav ms-auto">

                        @if (!(User.Identity?.IsAuthenticated ?? false))
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Register"
                                   asp-action="Index">

                                    Register

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Login"
                                   asp-action="Index">

                                    Login

                                </a>

                            </li>
                        }
                        else
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Home"
                                       asp-action="Index">
                                        Home
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Admin"
                                       asp-action="UserList">
                                        Users
                                    </a>
                                </li>
                            }
                            else
                            {
                                @if (isProfileVerified)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link"
                                           asp-controller="Home"
                                           asp-action="Index">
                                            Home
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link"
                                           asp-controller="Document"
                                           asp-action="Index">
                                            Manage Documents
                                        </a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Verification"
                                       asp-action="Status">
                                        Verification Status
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-secondary fw-semibold"
                                   asp-controller="Home"
                                   asp-action="Settings">
                                    Settings
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold"
                                   id="logoutLink"
                                   asp-controller="Login"
                                   asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    @if (User.IsInRole("Admin"))
    {
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

        <div class="container-fluid">

            <div class="row">

                <div class="col-md-2 sidebar p-4">

                    <div class="sidebar-brand mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-shield-fill-check text-primary fs-4"></i>
                        <h4 class="text-white mb-0 fw-bold">Admin Panel</h4>
                    </div>

                    <ul class="nav flex-column">

                        <li class="nav-item">

                            <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-controller="Home"
                               asp-action="Index">
                                <i class="bi bi-grid-1x2-fill"></i>
                                <span>Dashboard</span>
                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentController == "Admin" && currentAction == "UserList" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="UserList">
                                <i class="bi bi-people-fill"></i>
                                <span>User Master</span>
                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentController == "Admin" && (currentAction == "RoleList" || currentAction == "AddRole" || currentAction == "EditRole") ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="RoleList">
                                <i class="bi bi-shield-lock-fill"></i>
                                <span>Role Master</span>
                            </a>

                        </li>



                        <li class="nav-item">

                            <a class="nav-link @(currentController == "Admin" && currentAction == "PendingAdmins" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="PendingAdmins">

                                <i class="bi bi-person-check-fill"></i>
                                <span>Pending Admins</span>

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentController == "Admin" && currentAction == "SuspendedUsers" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="SuspendedUsers">

                                <i class="bi bi-lock-fill"></i>
                                <span>Suspended Users</span>

                            </a>

                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Admin" && currentAction == "VerificationDashboard" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="VerificationDashboard">
                                <i class="bi bi-patch-check-fill"></i>
                                <span>KYC Verification</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Admin" && currentAction == "ActivityLogs" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="ActivityLogs">
                                <i class="bi bi-journal-text"></i>
                                <span>Activity Logs</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Admin" && currentAction == "ErrorLogs" ? "active" : "")"
                               asp-controller="Admin"
                               asp-action="ErrorLogs">
                                <i class="bi bi-exclamation-triangle"></i>
                                <span>Error Logs</span>
                            </a>
                        </li>

                    </ul>

                </div>

                <div class="col-md-10 py-4 px-4">

                    @RenderBody()

                </div>

            </div>

        </div>
    }
    else
    {
    @if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Landing")
    {
        @RenderBody()
    }
    else
    {
        <main class="container py-4">

            @RenderBody()

        </main>
    }
    }

    <footer class="border-top footer text-muted py-3 mt-4">

        <div class="container text-center">

            &copy; 2026 - RegistrationFormProject

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>

        const canvas = document.getElementById("dotCanvas");
        if (canvas) {
            const ctx = canvas.getContext("2d");

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }

            resize();
            window.addEventListener("resize", resize);

            let offset = 0;

            function animate() {

                ctx.clearRect(0, 0, canvas.width, canvas.height);

                offset += 0.5;

                for (let x = -100; x < canvas.width + 100; x += 8) {

                    for (let y = -100; y < canvas.height + 100; y += 8) {

                        const value =
                            Math.sin((x + offset) * 0.02) *
                            Math.cos((y + offset) * 0.02);

                        const radius =
                            Math.abs(value) * 2.5;

                        ctx.beginPath();
                        ctx.arc(x, y, radius, 0, Math.PI * 2);
                        ctx.fillStyle = "rgba(0,0,0,0.35)";
                        ctx.fill();
                    }
                }

                requestAnimationFrame(animate);
            }

            animate();
        }

    </script>

    @if (TempData["Success"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3500,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                Toast.fire({
                    icon: 'success',
                    title: '@TempData["Success"]'
                });
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 4500,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                Toast.fire({
                    icon: 'error',
                    title: '@TempData["Error"]'
                });
            });
        </script>
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const logoutLink = document.getElementById("logoutLink");
            if (logoutLink) {
                logoutLink.addEventListener("click", function (e) {
                    e.preventDefault();
                    const logoutUrl = this.getAttribute("href");

                    Swal.fire({
                        title: 'Confirm Logout',
                        text: 'Are you sure you want to sign out of your account?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#2563eb',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: 'Yes, Logout',
                        cancelButtonText: 'Cancel',
                        background: 'rgba(255, 255, 255, 0.95)',
                        backdrop: `rgba(15, 23, 42, 0.4)`
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = logoutUrl;
                        }
                    });
                });
            }
        });
    </script>
</body>

</html>